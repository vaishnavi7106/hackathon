# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://uzhavar:uzhavar@localhost:5432/uzhavar
DATABASE_URL_SYNC=postgresql+psycopg2://uzhavar:uzhavar@localhost:5432/uzhavar

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# LLM provider (default: gemini — change to openai/anthropic/ollama when ready)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# External APIs
ENAM_API_KEY=
IMD_API_KEY=

# Media storage (use local path for hackathon)
MEDIA_STORAGE=local
LOCAL_MEDIA_PATH=./media
# AWS_S3_BUCKET=uzhavar-media
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# App
APP_ENV=development
LOG_LEVEL=info
