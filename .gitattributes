# Linguist language stats overrides

# Exclude npm lock file (142KB of JSON skewing stats)
frontend/package-lock.json linguist-generated=true

# Exclude large Alembic migration data files from language stats
backend/alembic/versions/*.py linguist-generated=true
backend/seed_main_db.py linguist-generated=true

# Exclude test fixtures (large conftest)
backend/tests/conftest.py linguist-generated=true

# Ensure TypeScript source is always detected
*.ts linguist-detectable=true
*.tsx linguist-detectable=true
